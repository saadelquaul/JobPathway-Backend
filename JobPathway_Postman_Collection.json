          "name": "Get All Job Offers",
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/job-offers?page=0&size=10&sort=createdAt,desc",
              "host": ["{{base_url}}"],
              "path": ["api", "job-offers"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"},
                {"key": "sort", "value": "createdAt,desc"}
              ]
            },
            "description": "Get all job offers (paginated). Public endpoint."
