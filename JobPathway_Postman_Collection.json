            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Java Developer\",\n  \"description\": \"We are looking for an experienced Java developer to join our team. You will be responsible for building scalable backend services.\",\n  \"location\": \"New York, NY\",\n  \"minExperience\": 5,\n  \"salaryRange\": \"$120,000 - $150,000\",\n  \"workModel\": \"HYBRID\",\n  \"jobType\": \"FULL_TIME\",\n  \"requiredSkills\": [\n    {\n      \"skillName\": \"Java\",\n      \"minimumLevel\": \"ADVANCED\"\n    },\n    {\n      \"skillName\": \"Spring Boot\",\n      \"minimumLevel\": \"INTERMEDIATE\"\n    },\n    {\n      \"skillName\": \"PostgreSQL\",\n      \"minimumLevel\": \"INTERMEDIATE\"\n    }\n  ]\n}"
