{
  "info": {
    "name": "JobPathway API v2",
    "description": "Complete Postman collection for the JobPathway Backend REST API. Includes all endpoints for Authentication, Candidate Profile Management, Job Offers, Applications, Admin User Management, and Notifications.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string",
      "description": "JWT token for admin user. Set after login."
    },
    {
      "key": "candidate_token",
      "value": "",
      "type": "string",
      "description": "JWT token for candidate user. Set after login."
    }
  ],
  "item": [
    {
      "name": "01. Auth",
      "description": "Authentication endpoints for user registration and login.",
      "item": [
        {
          "name": "Register Candidate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new candidate account. Returns JWT token on success."
          }
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@jobpathway.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as admin. Copy the token from response to admin_token variable."
          }
        },
        {
          "name": "Login (Candidate)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as candidate. Copy the token from response to candidate_token variable."
          }
        }
      ]
    },
