              "host": ["{{base_url}}"],
              "path": ["api", "job-offers"]
            },
            "description": "Create a new job offer. Admin only. WorkModel: ON_SITE, REMOTE, HYBRID. JobType: FULL_TIME, PART_TIME, CONTRACT, INTERNSHIP."
          }
